# Core Backend System Configuration

# -----------------------------------------------------------------------------
# Server Configuration (Node.js)
# -----------------------------------------------------------------------------
# The port where the core backend server listens.
CORE_PORT=4100
CORE_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# AI Server Configuration (Flask)
# -----------------------------------------------------------------------------
# Connection details for the AI Dummy Server.
# Used by both the AI server itself (to listen) and the Core Backend (to connect).
AI_HOST=127.0.0.1
AI_PORT=5000
# Optional: Override full URL if needed (e.g., in Docker: http://ai_dummy:5000)
# AI_BASE_URL=http://127.0.0.1:5000

# Timeout for AI requests (milliseconds)
AI_TIMEOUT_MS=120000

# -----------------------------------------------------------------------------
# Database Configuration (MySQL)
# -----------------------------------------------------------------------------
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=example
MYSQL_DATABASE=safe_hi
MYSQL_CONN_LIMIT=10

# -----------------------------------------------------------------------------
# Tenant Configuration
# -----------------------------------------------------------------------------
DEFAULT_TENANT=yangchun

# -----------------------------------------------------------------------------
# Security (CORS)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000
